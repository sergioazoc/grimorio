{
  "name": "grimorio-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter '!grimorio-docs' run build",
    "docs:dev": "pnpm --filter grimorio-docs dev",
    "docs:build": "pnpm --filter grimorio-docs build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsgo --noEmit -p packages/core/tsconfig.json && tsgo --noEmit -p packages/analyzers/tsconfig.json && tsgo --noEmit -p packages/validators/tsconfig.json && tsgo --noEmit -p packages/mcp/tsconfig.json && tsgo --noEmit -p packages/cli/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260323.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.2",
    "tsdown": "^0.21.4",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
