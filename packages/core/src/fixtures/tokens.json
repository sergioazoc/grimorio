{
  "color": {
    "$type": "color",
    "primary": {
      "$value": "#3b82f6",
      "$description": "Primary brand color"
    },
    "secondary": {
      "$value": "#64748b",
      "$description": "Secondary brand color"
    },
    "destructive": {
      "$value": "#ef4444"
    }
  },
  "spacing": {
    "$type": "dimension",
    "sm": { "$value": "0.5rem" },
    "md": { "$value": "1rem" },
    "lg": { "$value": "1.5rem" }
  },
  "typography": {
    "$type": "fontFamily",
    "sans": {
      "$value": "Inter, system-ui, sans-serif",
      "$extensions": {
        "com.grimorio.weight": "400"
      }
    }
  }
}
