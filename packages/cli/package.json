{
  "name": "grimorio",
  "version": "0.1.2",
  "description": "Design system infrastructure CLI — analyze components, generate specs, validate implementations, and expose your design system via MCP",
  "keywords": [
    "cli",
    "component-spec",
    "design-system",
    "design-tokens",
    "mcp",
    "react",
    "validation",
    "vue"
  ],
  "homepage": "https://github.com/sergioazoc/grimorio#readme",
  "bugs": {
    "url": "https://github.com/sergioazoc/grimorio/issues"
  },
  "license": "MIT",
  "author": "Sergio Azócar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergioazoc/grimorio.git",
    "directory": "packages/cli"
  },
  "bin": {
    "grimorio": "./bin/grimorio.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@vue/compiler-sfc": "^3.5.29",
    "c12": "4.0.0-beta.3",
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "jiti": "^2.6.1",
    "oxc-parser": "^0.116.0",
    "oxc-resolver": "^11.19.1",
    "tinyglobby": "^0.2.15",
    "zod": "catalog:",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "grimorio-analyzers": "workspace:*",
    "grimorio-core": "workspace:*",
    "grimorio-mcp": "workspace:*",
    "grimorio-validators": "workspace:*"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
